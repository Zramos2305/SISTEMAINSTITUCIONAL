rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       FUNCIONES SEGURAS
    ==========================*/

    function isLogged() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases//documents/usuarios/);
    }

    function userExists() {
      return isLogged() && exists(/databases//documents/usuarios/);
    }

    function userData() {
      return userDoc().data;
    }

    function isActiveUser() {
      return userExists() && userData().activo == true;
    }

    function isSuperAdmin() {
      return isActiveUser() && userData().rol == "superadmin";
    }

    function isRRHHOrSuperAdmin() {
      return isActiveUser() &&
        (userData().rol == "recursos_humanos" || userData().rol == "superadmin");
    }

    function isOwnerEmployee() {
      return isLogged() && resource.data.uidAuth == request.auth.uid;
    }

    /* =========================
       USUARIOS
    ==========================*/

    match /usuarios/{userId} {
      // IMPORTANTE: Primero comprobar si es el propio usuario para evitar loops infinitos
      allow read: if request.auth.uid == userId || isRRHHOrSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    /* =========================
       EMPLEADOS
    ==========================*/

    match /empleados/{empId} {
      allow read: if isOwnerEmployee() || isRRHHOrSuperAdmin();
      allow create: if isRRHHOrSuperAdmin();
      allow update: if isOwnerEmployee() || isRRHHOrSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    /* =========================
       ASISTENCIAS
    ==========================*/
    match /asistencias/{asistenciaId} {
      allow read: if (isLogged() && resource != null && resource.data.usuarioId == request.auth.uid) || isRRHHOrSuperAdmin();
      allow create: if isLogged() && request.resource.data.usuarioId == request.auth.uid;
      allow update: if isLogged() && resource.data.usuarioId == request.auth.uid;
      allow delete: if isSuperAdmin();
    }
    
    /* =========================
       AFILIADOS
    ==========================*/
    match /afiliados/{afiliadoId} {
      allow read: if true;
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    /* =========================
       DOCUMENTOS QR
    ==========================*/

    match /documentos/{docId} {
      allow read: if true;
      allow create: if isRRHHOrSuperAdmin();
      allow update: if isRRHHOrSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    /* =========================
       AUDITORÍA
    ==========================*/

    match /auditoria/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isRRHHOrSuperAdmin();
      allow update, delete: if false;
    }
  }
}

